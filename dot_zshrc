# ============================================================
# ghq
# ============================================================
# ghq で管理しているリポジトリを fzf で選択して cd
ghq-cd() {
  local repo=$(ghq list | fzf --preview "ls -la $(ghq root)/{}" --preview-window=right:60%)
  if [ -n "$repo" ]; then
    cd "$(ghq root)/$repo"
  fi
}
alias gc='ghq-cd'

# ghq get のエイリアス
alias gg='ghq get'

# ============================================================
# herdr / リモート Claude Code
# ============================================================
# macmini2.local に SSH 接続し、指定ディレクトリで Claude Code を起動
# herdr が SSH 越しでも agent として認識できるよう HERDR_AGENT を付与
cmini2() {
  local dir="${1:-~}"
  HERDR_AGENT=claude ssh macmini2.local -t "zsh -lic \"cd $dir && claude\""
}

# ============================================================
# git worktree
# ============================================================
# git worktree を fzf で選択して cd
wt() {
  local root=$(git worktree list --porcelain 2>/dev/null | awk '/^worktree/ {print $2}' | head -1)
  if [ -z "$root" ]; then
    echo "git worktree: not a git repository"
    return 1
  fi
  local worktree=$(git worktree list 2>/dev/null \
    | tail -r \
    | awk '{n=split($1,a,"/"); path=$1; $1=a[n]; print $0 "\t" path}' \
    | fzf --ansi \
          --delimiter='\t' \
          --with-nth=1 \
          --preview '
            s=$(git -C {2} status --short 2>/dev/null)
            if [ -n "$s" ]; then
              echo "\033[1;33m── Uncommitted Changes ──\033[0m"
              echo "$s"
              echo ""
              git -C {2} diff --stat --color=always 2>/dev/null
              echo ""
            fi
            echo "\033[1;36m── Recent Commits ──\033[0m"
            git -C {2} log -10 --color=always --pretty=format:"%C(bold #E6C384)%h%C(reset) %C(bold #7AA89F)%d%C(reset)%n  %C(#DCD7BA)%s%C(reset)%n  %C(#98BB6C)%an%C(reset) %C(#7E9CD8)%cr%C(reset)%n"
          ' \
          --preview-window=right:45%)
  if [ -n "$worktree" ]; then
    cd "$(echo "$worktree" | cut -f2)"
  fi
}

