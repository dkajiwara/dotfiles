#!/bin/bash
# Merge chezmoi-managed Cursor Agent CLI settings into the live cli-config.json.

set -euo pipefail

config="${XDG_CONFIG_HOME:-{{ .chezmoi.homeDir }}/.config}/cursor/cli-config.json"
fragment="{{ .chezmoi.sourceDir }}/dot_config/cursor/agent-cli.fragment.json"

mkdir -p "$(dirname "$config")"

if [[ ! -f "$config" ]]; then
  printf '%s\n' '{"version":1,"editor":{"vimMode":false},"permissions":{"allow":[],"deny":[]}}' >"$config"
fi

tmp="$(mktemp)"
jq --slurpfile frag "$fragment" '
  .statusLine = $frag[0].statusLine |
  .permissions.allow = $frag[0].permissions.allow |
  .permissions.deny = $frag[0].permissions.deny
' "$config" >"$tmp"
mv "$tmp" "$config"
