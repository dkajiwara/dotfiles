background-opacity = 0.85
background-blur-radius = 20
macos-titlebar-style = transparent
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor
desktop-notifications = true

# https://github.com/ghostty-org/ghostty/issues/5372#issuecomment-2614259192
font-feature = -calt
font-feature = -dlig
font-family = "Moralerspace Neon"
font-size = 13

# quick-terminal
quick-terminal-position=center
quick-terminal-screen=main


## Keybinds
keybind = shift+enter=text:\n
keybind = "global:cmd+shift+t=toggle_quick_terminal"

# tmux ペインジャンプ用 Meta キー (Option + 数字 → ESC + 数字)
keybind = alt+0=text:\x1b0
keybind = alt+1=text:\x1b1
keybind = alt+2=text:\x1b2
keybind = alt+3=text:\x1b3
keybind = alt+4=text:\x1b4
