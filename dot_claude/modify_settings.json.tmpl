#!/bin/bash
# chezmoi passes the current ~/.claude/settings.json content on stdin;
# stdout becomes the new content.
#
# Base content (everything chezmoi owns) lives in settings.base.json.
# enabledPlugins / advisorModel are explicitly passed through as-is from the
# live file, since Claude Code itself writes them via /config and plugin
# management — everything else always comes from the base.

set -euo pipefail

base="{{ .chezmoi.sourceDir }}/dot_claude/settings.base.json"

# env.PATH is machine-dependent (home dir), so it is assembled here at apply
# time instead of being hardcoded in settings.base.json.
claude_path="$HOME/.local/share/mise/shims"
claude_path="$claude_path:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
claude_path="$claude_path:$HOME/.cargo/bin:$HOME/.pub-cache/bin:$HOME/.local/bin:$HOME/go/bin"
claude_path="$claude_path:$HOME/Library/Android/sdk/platform-tools:$HOME/google-cloud-sdk/bin"
claude_path="$claude_path:/opt/homebrew/opt/fzf/bin"

jq --slurp --slurpfile base "$base" --arg path "$claude_path" '
  ($base[0]) as $base |
  (.[0] // {}) as $live |
  ($base + {enabledPlugins: ($live.enabledPlugins // {}), advisorModel: $live.advisorModel}) |
  .env.PATH = $path |
  if .advisorModel == null then del(.advisorModel) else . end
'
