# ============================================================
# fzf (Fuzzy Finder)
# ============================================================
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_COMMAND='rg --files --hidden --glob "!.git"'
export FZF_DEFAULT_OPTS='--height 40% --reverse --border --bind ctrl-j:down,ctrl-k:up,ctrl-d:half-page-down,ctrl-u:half-page-up'
export FZF_CTRL_T_OPTS='--preview "bat  --color=always --style=header,grid --line-range :100 {}"'

# ============================================================
# History
# ============================================================
setopt share_history
setopt hist_reduce_blanks
setopt hist_no_store
setopt hist_ignore_dups

# ============================================================
# Environment Variables
# ============================================================
export XDG_CONFIG_HOME="$HOME/.config"
export GOPATH="$HOME/go"
export PYENV_ROOT="$HOME/.pyenv"

setopt nonomatch

# ============================================================
# PATH
# ============================================================
export PATH="$PATH:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Library/Apple/usr/bin"
export PATH="$PATH:/opt/homebrew/bin:/opt/homebrew/sbin"
export PATH="$PATH:$HOME/Library/Android/sdk/platform-tools"
export PATH="$PATH:$HOME/.pub-cache/bin"
export PATH="$PATH:$PYENV_ROOT/bin"
export PATH="$PATH:$HOME/.tfenv/bin"
export PATH="$PATH:$HOME/.local/bin"
export PATH="$PATH:$GOPATH/bin"
export ANDROID_HOME="$HOME/Library/Android/sdk"

# 重複パスを登録しない
typeset -U path PATH

# ============================================================
# Version Managers
# ============================================================
# pyenv
eval "$(pyenv init -)"

# ============================================================
# Tools
# ============================================================
eval "$(mise activate zsh)"
eval "$(direnv hook zsh)"
eval "$(sheldon source)"
eval "$(zoxide init zsh)"

# ============================================================
# Completion
# ============================================================
autoload -U compinit && compinit

# carapace (mise でインストールされるため、mise activate の後に配置)
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
source <(carapace _carapace)

# make: Makefile の ## コメントを補完の説明として表示
_make_targets_with_desc() {
  local makefile
  for makefile in Makefile makefile GNUmakefile; do
    [[ -f $makefile ]] && break
  done
  [[ -f $makefile ]] || return

  local -a targets
  targets=("${(@f)$(awk -F':.*?## ' '/^[a-zA-Z0-9_-]+:.*## / {printf "%s:%s\n", $1, $2}' "$makefile")}")
  _describe 'make target' targets
}
compdef _make_targets_with_desc make

